# Copy this file to .env and fill in your values

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=welcome123

# Amazon Bedrock (required for Supervisor / Planner / Critic / match/agent reasoning)
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-opus-4-7
# If the base ID fails in your account, try:
# BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-7
