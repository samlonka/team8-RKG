# Copy this file to .env and fill in your values

# ── PostgreSQL (AWS RDS) ──────────────────────────────────────────────────────
POSTGRES_HOST=rfknowledgegraph-topic-3.cydaas28c2yx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=team8_db
POSTGRES_USER=postgres
# Set a password here, or leave empty and use POSTGRES_SECRET_ID + AWS credentials
POSTGRES_PASSWORD=
POSTGRES_SECRET_ID=rds!db-259bad4d-76af-44ff-8967-aa765bb03770
POSTGRES_CONNECT_TIMEOUT=15
# require | prefer | disable — leave empty to omit sslmode from the connection
POSTGRES_SSLMODE=require

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=welcome123

# ── Amazon Bedrock ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-opus-4-7
# If the base ID fails in your account, try:
# BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-7
# All four agents (Supervisor/Planner/Doer/Critic) call Bedrock when true; rule-based fallback when false or unavailable
AGENT_USE_LLM=true
